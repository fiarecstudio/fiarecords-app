
# ==========================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - FIA RECORDS
# ==========================================

# --- Configuración del Servidor ---
PORT=5000
NODE_ENV=development

# --- Base de Datos MongoDB ---
MONGO_URI=tu_mongo_uri_aqui

# --- JWT (Autenticación) ---
JWT_SECRET=change_this_secret_to_a_very_long_random_string

# --- Google APIs ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# --- Gmail API (Para envío de correos) ---
EMAIL_USER=tu_email@gmail.com
GMAIL_CLIENT_ID=tu_gmail_client_id_aqui
GMAIL_CLIENT_SECRET=tu_gmail_client_secret_aqui
GMAIL_REFRESH_TOKEN=tu_gmail_refresh_token_aqui

# --- URLs de la Aplicación ---
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# --- Configuración de Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
